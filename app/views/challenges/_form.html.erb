<%= render 'shared/challenge_js' %>
<div class="challenge-form">
  <h4 class="challenge-form-title">Your Challenge</h4>
  <%= form_with(model: [claim, challenge], local: false, class: "challenge-form-ajax") do |f| %>
    <% if challenge.errors.any? %>
      <div class="error-messages">
        <% challenge.errors.full_messages.each do |message| %>
          <p class="error"><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="challenge-form-row">
      <div class="challenge-form-avatar">
        <%= image_tag (current_user.avatar_url.presence || 'default-avatar.png'), alt: current_user.full_name || 'You', class: 'challenge-form-avatar-img' %>
      </div>
      <div class="challenge-form-field-wrap">
        <%= f.text_area :text, rows: 1, placeholder: "Write your challenge...", class: "form-control challenge-form-textarea" %>
        <div class="form-actions">
          <%= f.submit "Submit", class: "btn btn-primary challenge-submit-btn" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
