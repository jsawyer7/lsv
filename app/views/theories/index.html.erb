<script>
  window.FEED_API_URL = '/theories/infinite';
  window.FEED_FILTER = '<%= j (params[:filter].presence || 'public') %>';
  window.FEED_TYPE = 'theories';
</script>
<div class="feed-main theories-page-main">
  <div class="theories-page-content">
    <header class="theories-page-header">
      <h1 class="theories-page-title">Theories</h1>
      <nav class="theories-page-filters">
        <%= link_to 'Public', theories_path(filter: 'public'), class: "theories-filter-pill #{'active' if params[:filter].blank? || params[:filter] == 'public'}" %>
        <%= link_to 'In Review', theories_path(filter: 'in_review'), class: "theories-filter-pill #{'active' if params[:filter] == 'in_review'}" %>
        <%= link_to 'Draft', theories_path(filter: 'draft'), class: "theories-filter-pill #{'active' if params[:filter] == 'draft'}" %>
      </nav>
    </header>
    <div id="feed-list" class="feed-list">
    </div>
    <div id="feed-loader" class="feed-loader">Loading...</div>
  </div>
  <aside class="feed-rightbar facts-page-rightbar">
    <%= render 'facts/rightbar' %>
  </aside>
</div>
<%= render 'shared/theories_feeds_js' %>
