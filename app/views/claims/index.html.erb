<%= render 'shared/claim_js' %>
<%= render 'shared/publish_fact_js' %>

<div class="my-claims-page <%= 'claims-page-facts-tab' if @filter == 'facts' %>">
  <div class="my-claims-header-row">
    <h2 class="my-claims-title">Claims</h2>
  </div>
  <nav class="my-claims-filter-bar">
    <% filters = { 'all' => 'New', 'drafts' => 'Drafts', 'ai_validated' => 'AI Validated', 'verified' => 'Verified' } %>
    <% filters.each do |key, label| %>
      <%= link_to label, claims_path(filter: key), class: "my-claims-filter-pill #{'active' if @filter == key}" %>
    <% end %>
    <%= link_to 'Facts', claims_path(filter: 'facts'), class: "my-claims-filter-pill #{'active' if @filter == 'facts'}" %>
  </nav>
  <div class="my-claims-list">
    <% @claims.each do |claim| %>
      <% if @filter == 'facts' %>
        <div class="my-claim-card-wrapper">
          <%= render 'shared/feed_card', fact: claim %>
        </div>
      <% else %>
        <div class="my-claim-card js-card-clickable <%= 'is-draft' if claim.state == 'draft' %>" data-detail-url="<%= claim_path(claim) %>">
          <div class="my-claim-card-header">
            <div class="my-claim-user">
              <%= image_tag claim.user.avatar_url.presence || 'default-avatar.png', class: 'my-claim-avatar' %>
              <div class="my-claim-user-info">
                <div class="my-claim-user-name-row">
                  <span class="my-claim-user-name"><%= claim.user.full_name.presence || claim.user.email %></span>
                  <%= image_tag 'blue-tick.svg', alt: 'Verified', class: 'my-claim-verified-icon' %>
                </div>
                <div class="my-claim-user-rating"><span class="my-claim-stars">★★★★★</span><span class="my-claim-rating-value">4.7</span></div>
              </div>
            </div>
            <% unless @filter == 'verified' %>
              <% if claim.state == 'ai_validated' && !claim.fact? %>
                <% if @filter == 'ai_validated' %>
                  <span class="my-claim-badge verification-pending">Verification Pending</span>
                <% else %>
                  <span class="my-claim-badge ai-validated">Review Pending</span>
                <% end %>
              <% elsif claim.state == 'verified' %>
                <span class="my-claim-badge verified">Verified</span>
              <% end %>
            <% end %>
          </div>
          <div class="my-claim-content"><%= truncate(claim.content_for_user(current_user), length: 220) %></div>
          <% if @filter == 'verified' %>
            <button type="button" class="my-claim-make-public-btn btn-publish-fact" data-claim-id="<%= claim.id %>" data-no-card-nav>Make Public</button>
          <% end %>
          <% if @filter == 'drafts' %>
            <div class="my-claim-card-footer">
              <% if claim.state == 'draft' %>
                <%= link_to edit_claim_path(claim), class: 'my-claim-edit-link my-claim-draft-action' do %>
                  <%= image_tag 'edit.svg', alt: 'Edit', class: 'my-claim-draft-icon' %>
                <% end %>
                <a href="#" class="my-claim-delete-link my-claim-draft-action" data-claim-id="<%= claim.id %>" data-no-card-nav>
                  <%= image_tag 'Delete.svg', alt: 'Delete', class: 'my-claim-draft-icon' %>
                </a>
              <% else %>
                <%= link_to "View Details", claim_path(claim), class: "my-claim-view-link" %>
                <a href="#" class="my-claim-delete-link" data-claim-id="<%= claim.id %>" data-no-card-nav><i class="fa fa-trash"></i> Delete</a>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @claims.empty? %>
    <div class="empty-state">
      <p><%= @filter == 'facts' ? 'No facts yet.' : 'No claims have been submitted yet.' %></p>
    </div>
  <% else %>
    <div class="pagination-container">
      <%= paginate @claims %>
    </div>
  <% end %> 
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-claim-modal" class="delete-claim-modal-overlay" style="display:none;">
  <div class="delete-claim-modal">
    <button type="button" class="delete-claim-modal-close-wrap" onclick="closeDeleteClaimModal()" aria-label="Close">
      <%= image_tag 'crossbutton.svg', alt: '', class: 'delete-claim-modal-close-icon' %>
    </button>
    <div class="delete-claim-modal-content">
      <div class="delete-claim-modal-icon-wrap">
        <%= image_tag 'Delete.svg', alt: '', class: 'delete-claim-modal-icon' %>
      </div>
      <p class="delete-claim-modal-text">Are you sure you want to delete this claim?</p>
    </div>
    <form id="delete-claim-form" method="post" class="delete-claim-modal-form">
      <input type="hidden" name="_method" value="delete">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button type="submit" class="delete-claim-modal-confirm">Delete</button>
    </form>
  </div>
</div>

<!-- Publish Success Modal (Make Public flow) -->
<div id="publish-success-modal" class="publish-success-modal-overlay" style="display:none;">
  <div class="publish-success-modal">
    <button type="button" class="publish-success-modal-close-wrap" onclick="closePublishSuccessModal()" aria-label="Close">
      <%= image_tag 'crossbutton.svg', alt: '', class: 'publish-success-modal-close-icon' %>
    </button>
    <div class="publish-success-modal-icon-block">
      <%= image_tag 'blue-tick.svg', alt: '', class: 'publish-success-modal-icon' %>
      <span class="publish-success-modal-title">Claim Published</span>
    </div>
    <p class="publish-success-modal-description">Your claim has been successfully published to the feed and is now considered a fact.</p>
    <button type="button" class="publish-success-done-btn" onclick="closePublishSuccessModal()">Done</button>
  </div>
</div>
