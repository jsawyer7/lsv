<div class="claim-main">
  <div class="claim-center">
    <div class="claim-header">
      <h2><%= @show_as_fact ? 'Fact Details' : 'Claim Details' %></h2>

    </div>

    <div class="claim-details-title-block">
      <div class="claim-details-title claim-detail-card-style">
        <div class="claim-detail-card-icon">
          <%= image_tag 'claimicon.svg', alt: 'Claim', class: 'claim-detail-icon-img' %>
        </div>
        <div class="claim-detail-card-header">
          <span class="claim-details-label">Claim</span>
          <span class="claim-details-date"><%= @claim.created_at.strftime('%d %b, %Y') %></span>
          <% if @show_as_fact && @claim.fact? %>
            <span class="claim-detail-fact-badge">Fact</span>
          <% end %>
        </div>
        <div class="claim-details-content" id="claim-content">
          <%= @claim.content_for_tradition(@tradition) %>
        </div>
        <div class="feed-card-divider"></div>
        <div class="feed-card-verified-by">
          <span class="verified-by-label">Verified by:</span>
          <div class="verified-by-avatars">
            <%= image_tag 'default-avatar.png', alt: 'Verifier', class: 'verified-by-avatar' %>
            <%= image_tag 'default-avatar.png', alt: 'Verifier', class: 'verified-by-avatar' %>
          </div>
        </div>
        <div class="feed-card-actions-wrapper" data-no-card-nav>
          <div class="feed-card-actions">
            <div class="feed-action-like">
              <% if user_signed_in? %>
                <% user_like = @claim.likes.find_by(user: current_user) %>
                <% if user_like %>
                  <%= link_to claim_like_path(@claim, user_like), method: :delete, remote: true, class: 'feed-like liked', data: { claim_id: @claim.id } do %>
                    <%= image_tag 'like.svg', alt: 'Like', class: 'like-icon' %>
                    <span class="like-count"><%= @claim.likes.count %></span>
                  <% end %>
                <% else %>
                  <%= link_to claim_likes_path(@claim), method: :post, remote: true, class: 'feed-like', data: { claim_id: @claim.id } do %>
                    <%= image_tag 'like.svg', alt: 'Like', class: 'like-icon' %>
                    <span class="like-count"><%= @claim.likes.count %></span>
                  <% end %>
                <% end %>
              <% else %>
                <div class="feed-like">
                  <%= image_tag 'like.svg', alt: 'Like', class: 'like-icon' %>
                  <span class="like-count"><%= @claim.likes.count %></span>
                </div>
              <% end %>
            </div>
            <a href="#challenges" class="feed-action-comment" style="cursor: pointer;">
              <%= image_tag 'comment.svg', alt: 'Comment', class: 'comment-icon' %>
              <% comment_count = user_signed_in? ? @claim.comments.visible_to(current_user).count : @claim.comments.count %>
              <% if comment_count > 0 %>
                <span class="comment-count"><%= comment_count %></span>
              <% end %>
              <span class="comment-text">Comment</span>
            </a>
            <div class="feed-action-share">
              <button type="button" class="feed-share-btn" data-shareable-type="claim" data-shareable-id="<%= @claim.id %>" data-toggle="modal" data-target="#shareModal">
                <%= image_tag 'share.svg', alt: 'Share', class: 'share-icon' %>
                <span class="share-text">Share</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="claim-details-list">
      <div class="claim-details-evidence-card">
        <div class="claim-details-section">
          <div class="claim-details-evidence" id="evidence-content">
            <% @claim.evidences.each_with_index do |evidence, idx| %>
              <div class="claim-evidence-block" id="evidence-<%= evidence.id %>">
                <div class="evidence-card-header">
                  <div class="evidence-header-left">
                    <%= image_tag 'evidenceicon.svg', alt: 'Evidence Icon', class: 'claim-section-icon' %>
                    <span class="claim-details-label"><%= @claim.evidences.size > 1 ? "Evidence #{idx + 1}" : "Evidence" %></span>
                  </div>
                  <div class="evidence-header-actions">
                    <% if user_signed_in? %>
                      <% if current_user.can_submit_challenges? %>
                        <button type="button" class="btn btn-challenge-evidence" data-evidence-id="<%= evidence.id %>">Challenge Evidence</button>
                      <% else %>
                        <%= link_to "Challenge Evidence",
                                    subscription_settings_path(challenge_upgrade: 1),
                                    class: "btn btn-challenge-evidence" %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                <div class="evidence-sources-row">
                  <% evidence.source_names.each do |source_name| %>
                    <span class="source-badge"><%= source_name.humanize %></span>
                  <% end %>
                </div>
                <div class="evidence-content">
                  <% evidence.evidence_sections.each do |section_type, section_data| %>
                    <div class="evidence-section">
                      <% if section_data.is_a?(Array) %>
                        <% section_data.each_with_index do |item, index| %>
                          <div class="evidence-item">
                            <% case section_type %>
                            <% when 'verse' %>
                              <% if item['content'].present? %>
                                <div class="evidence-detail">
                                  <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['content'], @tradition) : item['content'] %>
                                </div>
                              <% end %>
                              <% if item['verse_reference'].present? %>
                                <div class="evidence-detail">
                                  <strong>Reference:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['verse_reference'], @tradition) : item['verse_reference'] %>
                                </div>
                              <% end %>
                              <% if item['original_text'].present? %>
                                <div class="evidence-detail">
                                  <strong>Original Text:</strong> <%= item['original_text'] %>
                                </div>
                              <% end %>
                              <% if item['translation'].present? %>
                                <div class="evidence-detail">
                                  <strong>Translation:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['translation'], @tradition) : item['translation'] %>
                                </div>
                              <% end %>
                              <% if item['explanation'].present? %>
                                <div class="evidence-detail">
                                  <strong>Explanation:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['explanation'], @tradition) : item['explanation'] %>
                                </div>
                              <% end %>
                            <% when 'historical' %>
                              <% if item['content'].present? %>
                                <div class="evidence-detail">
                                  <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['content'], @tradition) : item['content'] %>
                                </div>
                              <% end %>
                              <% if item['historical_event'].present? %>
                                <div class="evidence-detail">
                                  <strong>Historical Event:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['historical_event'], @tradition) : item['historical_event'] %>
                                </div>
                              <% end %>
                              <% if item['description'].present? %>
                                <div class="evidence-detail">
                                  <strong>Description:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['description'], @tradition) : item['description'] %>
                                </div>
                              <% end %>
                              <% if item['relevance'].present? %>
                                <div class="evidence-detail">
                                  <strong>Relevance:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['relevance'], @tradition) : item['relevance'] %>
                                </div>
                              <% end %>
                            <% when 'definition' %>
                              <% if item['content'].present? %>
                                <div class="evidence-detail">
                                  <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['content'], @tradition) : item['content'] %>
                                </div>
                              <% end %>
                              <% if item['term'].present? %>
                                <div class="evidence-detail">
                                  <strong>Term:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['term'], @tradition) : item['term'] %>
                                </div>
                              <% end %>
                              <% if item['definition'].present? %>
                                <div class="evidence-detail">
                                  <strong>Definition:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['definition'], @tradition) : item['definition'] %>
                                </div>
                              <% end %>
                              <% if item['etymology'].present? %>
                                <div class="evidence-detail">
                                  <strong>Etymology:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['etymology'], @tradition) : item['etymology'] %>
                                </div>
                              <% end %>
                              <% if item['usage_context'].present? %>
                                <div class="evidence-detail">
                                  <strong>Usage Context:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['usage_context'], @tradition) : item['usage_context'] %>
                                </div>
                              <% end %>
                            <% when 'logic' %>
                              <% if item['content'].present? %>
                                <div class="evidence-detail">
                                  <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['content'], @tradition) : item['content'] %>
                                </div>
                              <% end %>
                              <% if item['premise'].present? %>
                                <div class="evidence-detail">
                                  <strong>Premise:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['premise'], @tradition) : item['premise'] %>
                                </div>
                              <% end %>
                              <% if item['reasoning'].present? %>
                                <div class="evidence-detail">
                                  <strong>Reasoning:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['reasoning'], @tradition) : item['reasoning'] %>
                                </div>
                              <% end %>
                              <% if item['conclusion'].present? %>
                                <div class="evidence-detail">
                                  <strong>Conclusion:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(item['conclusion'], @tradition) : item['conclusion'] %>
                                </div>
                              <% end %>
                            <% end %>
                          </div>
                        <% end %>
                      <% else %>
                        <% case section_type %>
                        <% when 'verse' %>
                          <% if section_data['content'].present? %>
                            <div class="evidence-detail">
                              <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['content'], @tradition) : section_data['content'] %>
                            </div>
                          <% end %>
                          <% if section_data['verse_reference'].present? %>
                            <div class="evidence-detail">
                              <strong>Reference:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['verse_reference'], @tradition) : section_data['verse_reference'] %>
                            </div>
                          <% end %>
                          <% if section_data['original_text'].present? %>
                            <div class="evidence-detail">
                              <strong>Original Text:</strong> <%= section_data['original_text'] %>
                            </div>
                          <% end %>
                          <% if section_data['translation'].present? %>
                            <div class="evidence-detail">
                              <strong>Translation:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['translation'], @tradition) : section_data['translation'] %>
                            </div>
                          <% end %>
                          <% if section_data['explanation'].present? %>
                            <div class="evidence-detail">
                              <strong>Explanation:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['explanation'], @tradition) : section_data['explanation'] %>
                            </div>
                          <% end %>
                        <% when 'historical' %>
                          <% if section_data['content'].present? %>
                            <div class="evidence-detail">
                              <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['content'], @tradition) : section_data['content'] %>
                            </div>
                          <% end %>
                          <% if section_data['historical_event'].present? %>
                            <div class="evidence-detail">
                              <strong>Historical Event:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['historical_event'], @tradition) : section_data['historical_event'] %>
                            </div>
                          <% end %>
                          <% if section_data['description'].present? %>
                            <div class="evidence-detail">
                              <strong>Description:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['description'], @tradition) : section_data['description'] %>
                            </div>
                          <% end %>
                          <% if section_data['relevance'].present? %>
                            <div class="evidence-detail">
                              <strong>Relevance:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['relevance'], @tradition) : section_data['relevance'] %>
                            </div>
                          <% end %>
                        <% when 'definition' %>
                          <% if section_data['content'].present? %>
                            <div class="evidence-detail">
                              <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['content'], @tradition) : section_data['content'] %>
                            </div>
                          <% end %>
                          <% if section_data['term'].present? %>
                            <div class="evidence-detail">
                              <strong>Term:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['term'], @tradition) : section_data['term'] %>
                            </div>
                          <% end %>
                          <% if section_data['definition'].present? %>
                            <div class="evidence-detail">
                              <strong>Definition:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['definition'], @tradition) : section_data['definition'] %>
                            </div>
                          <% end %>
                          <% if section_data['etymology'].present? %>
                            <div class="evidence-detail">
                              <strong>Etymology:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['etymology'], @tradition) : section_data['etymology'] %>
                            </div>
                          <% end %>
                          <% if section_data['usage_context'].present? %>
                            <div class="evidence-detail">
                              <strong>Usage Context:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['usage_context'], @tradition) : section_data['usage_context'] %>
                            </div>
                          <% end %>
                        <% when 'logic' %>
                          <% if section_data['content'].present? %>
                            <div class="evidence-detail">
                              <strong>LSV Note:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['content'], @tradition) : section_data['content'] %>
                            </div>
                          <% end %>
                          <% if section_data['premise'].present? %>
                            <div class="evidence-detail">
                              <strong>Premise:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['premise'], @tradition) : section_data['premise'] %>
                            </div>
                          <% end %>
                          <% if section_data['reasoning'].present? %>
                            <div class="evidence-detail">
                              <strong>Reasoning:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['reasoning'], @tradition) : section_data['reasoning'] %>
                            </div>
                          <% end %>
                          <% if section_data['conclusion'].present? %>
                            <div class="evidence-detail">
                              <strong>Conclusion:</strong> <%= @tradition ? evidence.class.name_normalization_service.denormalize_text(section_data['conclusion'], @tradition) : section_data['conclusion'] %>
                            </div>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% primary_reasonings = @claim.reasonings.where(primary_source: true) %>
      <% any_validated = primary_reasonings.any? { |r| r.result == '✅ True' } %>
      <% claim_result = @claim.result %>
      <div class="claim-details-card claim-details-ai-validator-card">
        <div class="claim-details-section">
          <div class="claim-section-heading">
            <%= image_tag 'airesponse.svg', alt: 'AI Validator', class: 'claim-section-icon' %>
            <span class="claim-details-label">AI Validator Response</span>
          </div>
          <div id="reasoning-content" class="ai-validator-response-body">
            <% if any_validated %>
              <div class="ai-validator-status">
                <span class="ai-validator-status-icon" aria-hidden="true"></span>
                <span class="ai-validator-status-text">Claim Validated.</span>
              </div>
              <p class="ai-validator-consistent-with">This claim is consistent with:</p>
              <ul class="ai-validator-sources">
                <% primary_reasonings.each do |reasoning| %>
                  <li class="ai-validator-source-line">
                    <strong><%= ai_validator_source_label(reasoning.source) %>:</strong>
                    <span class="ai-validator-verse"><%= ai_validator_verse_display(reasoning.source, reasoning.response_for_tradition(@tradition)) %></span>
                  </li>
                <% end %>
              </ul>
            <% end %>
            <div class="ai-validator-verdict">
              <span class="ai-validator-verdict-label">Verdict:</span>
              <div class="ai-validator-verdict-row">
                <% verdict_word = claim_result == '✅ True' ? 'TRUE' : (claim_result == '❌ False' ? 'False' : (claim_result == '⚠️ Unverifiable' ? 'Unverifiable' : nil)) %>
                <% if verdict_word %>
                  <span class="ai-validator-verdict-word"><%= verdict_word %></span>
                <% end %>
                <% if claim_result == '✅ True' %>
                  <span class="ai-validator-verdict-icon" aria-hidden="true"></span>
                <% end %>
                <span class="ai-validator-verdict-lsv-line"><%= ai_validator_lsv_line(@claim, primary_reasonings) %></span>
              </div>
              <% other_verdict = ai_validator_verdict_real_text(primary_reasonings, @tradition) %>
              <% if other_verdict.present? %>
                <div class="ai-validator-verdict-text"><%= format_ai_response(other_verdict) %></div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="claim-details-card claim-details-peer-insight-card">
        <%= image_tag 'peerinsight.svg', alt: 'Peer Insight', class: 'peer-insight-icon' %>
        <div class="peer-insight-header">
          <span class="peer-insight-title">Peer Insight</span>
        </div>
        <div class="peer-insight-body">
          <p class="peer-insight-quote">This claim aligns with over 12 passages across canonical scripture and early historical sects. A critical distinction between Jesus as a prophet/messenger/avatar vs. God Himself is consistently supported.</p>
          <p class="peer-insight-attribution">- @FaithLogicVerified</p>
        </div>
      </div>

      <% if @claim.fact? && user_signed_in? && @claim.user == current_user %>
      <div class="claim-details-card claim-details-publish-fact-card">
        <div class="claim-publish-section">
          <div class="claim-section-heading">
            <%= image_tag 'fact-icon.png', alt: 'Fact', class: 'claim-section-icon' %>
            <span class="claim-details-label">Publish Fact</span>
          </div>
          <div class="publish-fact-actions">
            <% if @claim.published? %>
              <button class="btn btn-unpublish-fact" data-claim-id="<%= @claim.id %>">
                <i class="fa fa-eye-slash"></i> Unpublish Fact
              </button>
            <% else %>
              <button class="btn btn-publish-fact" data-claim-id="<%= @claim.id %>">
                <i class="fa fa-globe"></i> Publish Fact
              </button>
            <% end %>
          </div>
        </div>
      </div>
      <% end %>

      <div class="claim-details-card claim-details-challenge-card claim-challenges">
        <h3 class="challenge-block-title">Challenge</h3>
        <div id="challenges" class="challenge-list">
          <%= render partial: 'challenges/challenge', collection: @claim.challenges.where.not(evidence_id: nil).order(created_at: :desc) %>
        </div>
        <% if user_signed_in? %>
          <div id="challenge_form" class="challenge-form-wrapper">
            <%= render 'challenges/form', claim: @claim, challenge: @claim.challenges.new %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <aside class="claim-rightbar">
    <div class="claim-sidebar-card claim-posted-by">
      <h3>Posted by</h3>
      <div class="claim-sidebar-profile-row">
        <%= image_tag (@claim.user.avatar_url.presence || 'default-avatar.png'), alt: @claim.user.full_name || 'User', class: 'claim-sidebar-avatar' %>
        <div class="claim-sidebar-profile-info">
          <span class="claim-sidebar-name"><%= @claim.user.full_name.presence || @claim.user.email %></span>
          <span class="claim-sidebar-rating">4.7</span>
        </div>
      </div>
    </div>

    <div class="claim-sidebar-card claim-verified-by">
      <h3>Verified by</h3>
      <% 2.times do %>
        <div class="claim-sidebar-verifier-entry">
          <%= image_tag 'default-avatar.png', alt: 'Verifier', class: 'claim-sidebar-avatar' %>
          <div class="claim-sidebar-verifier-info">
            <div class="claim-sidebar-name-row">
              <span class="claim-sidebar-name">Mitchaly Carry</span>
              <%= image_tag 'blue-tick.svg', alt: 'Verified', class: 'claim-sidebar-verified-icon' %>
            </div>
            <p class="claim-sidebar-description">Islamic Scholar • Top Religion Person</p>
            <button type="button" class="claim-sidebar-follow-btn" disabled>+ Follow</button>
          </div>
        </div>
      <% end %>
    </div>

    <div class="claim-sidebar-card claim-primary-source">
      <h3>Primary Source</h3>
      <div class="claim-sidebar-source-list">
        <% @claim.reasonings.where(primary_source: true).each do |reasoning| %>
          <span class="claim-sidebar-source-pill claim-sidebar-source-pill--primary clickable-source-badge" data-source="<%= reasoning.source %>"><%= image_tag 'sourcefind.svg', alt: '', class: 'claim-sidebar-source-pill-icon' %><%= reasoning.source %></span>
        <% end %>
      </div>
    </div>

    <div class="claim-sidebar-card claim-secondary-source">
      <h3>Secondary Source</h3>
      <div class="claim-sidebar-source-list">
        <% @claim.reasonings.where(primary_source: false).each do |reasoning| %>
          <span class="claim-sidebar-source-pill claim-sidebar-source-pill--secondary clickable-source-badge" data-source="<%= reasoning.source %>"><%= image_tag 'secsource.svg', alt: '', class: 'claim-sidebar-source-pill-icon' %><%= reasoning.source %></span>
        <% end %>
      </div>
    </div>

    <div id="dynamic-ai-response-section"></div>
  </aside>
</div>

<div class="processing-overlay">
  <div class="loader-container">
    <div class="loader"></div>
    <p class="loader-text">Processing your challenge...</p>
  </div>
</div>

<div class="processing-overlay" id="evidence-challenge-loader" style="display:none;">
  <div class="loader-container">
    <div class="loader"></div>
    <p class="loader-text">Submitting your challenge...</p>
  </div>
</div>

<div id="evidence-challenge-modal" class="modal" style="display:none;">
  <div class="modal-content">
    <span class="close" id="close-evidence-challenge-modal">&times;</span>
    <h3>Challenge Evidence</h3>
    <form id="evidence-challenge-form">
      <label for="evidence-challenge-evidence-text" class="evidence-modal-label">Evidence</label>
      <textarea id="evidence-challenge-evidence-text" class="form-control evidence-modal-evidence-text" readonly style="min-height:65px;"></textarea>
      <label for="evidence-challenge-text" class="evidence-modal-label">Challenge</label>
      <textarea name="challenge[text]" id="evidence-challenge-text" rows="4" placeholder="Enter your challenge here..." class="form-control"></textarea>
      <input type="hidden" id="evidence-challenge-evidence-id" name="evidence_id" />
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Submit Challenge</button>
      </div>
      <div class="error-message" id="evidence-challenge-error" style="color:#ef4444;display:none;"></div>
    </form>
  </div>
</div>

<%= render 'shared/claim_detail_js' %>
<%= render 'shared/evidence_challenge_js' %>
<%= render 'shared/publish_fact_js' %>
