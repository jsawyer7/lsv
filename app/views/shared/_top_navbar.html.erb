<nav class="top-navbar">
  <div class="top-navbar-container">
    <!-- Logo -->
    <div class="top-navbar-logo">
      <%= link_to root_path do %>
        <%= image_tag "verifaith-logo.png", alt: "VeriFaith Logo", class: "logo-img" %>
      <% end %>
    </div>

    <!-- Search Bar -->
    <div class="top-navbar-search">
      <%= form_with url: dashboard_path, method: :get, local: true, class: "search-form", data: { controller: "search" } do |f| %>
        <%= image_tag "search.svg", alt: "Search", class: "search-icon-img" %>
        <%= f.text_field :search, 
            placeholder: "Search",
            value: params[:search],
            class: "search-input",
            data: { search_target: "input" } %>
      <% end %>
    </div>


    <div class="feeds-tab-wrapper">
      <%= link_to feeds_path, class: "nav-tab feeds-tab #{'active' if current_page?(feeds_path)}" do %>
        <%= image_tag 'feeds.svg', alt: 'Feeds', class: 'nav-tab-icon' %>
        <span class="nav-tab-text">Feeds</span>
      <% end %>
    </div>
    
    <div class="top-navbar-nav">

      <!-- My Peers -->
      <%= link_to peers_path, class: "nav-tab vertical-tab #{'active' if current_page?(peers_path) || request.path =~ %r{^/users/\d+/profile/?$}}" do %>
        <%= image_tag 'mypeers.svg', alt: 'My Peers', class: 'nav-tab-icon' %>
        <span class="nav-tab-text">My Peers</span>
      <% end %>

      <!-- Groups -->
      <a href="#" class="nav-tab vertical-tab upcoming">
        <%= image_tag 'groups.svg', alt: 'Groups', class: 'nav-tab-icon' %>
        <span class="nav-tab-text">Groups</span>
      </a>

      <!-- Notifications -->
      <% unread_count = unread_notifications_count %>
      <div class="nav-tab vertical-tab notifications-tab <%= 'active' if current_page?(notifications_path) %>" id="notifications-tab">
        <div class="notification-icon-wrapper">
          <%= image_tag (unread_count > 0 ? 'notification.svg' : 'notification-full.svg'), alt: 'Notifications', class: 'nav-tab-icon' %>
          <% if unread_count > 0 %>
            <span class="notification-badge"><%= unread_count > 9 ? '9+' : unread_count %></span>
          <% end %>
        </div>
        <span class="nav-tab-text">Notifications</span>

        <div class="notifications-dropdown-menu" id="notifications-dropdown-menu">
          <div class="notifications-dropdown-header">
            <h3 class="notifications-dropdown-title">Notifications</h3>
            <%= button_to 'Mark all as read', notifications_mark_all_read_path, method: :post, class: 'notifications-mark-read-btn', form: { class: 'notifications-mark-read-form' } %>
          </div>
          <div class="notifications-dropdown-tabs" role="tablist">
            <div class="notifications-dropdown-tab notifications-dropdown-tab--all active" role="presentation">
              <span class="notifications-dropdown-tab-label">All</span>
              <% if unread_count.positive? %>
                <span class="notifications-dropdown-tab-badge"><%= unread_count > 9 ? '9+' : unread_count %></span>
              <% end %>
            </div>
            <span class="notifications-dropdown-tab notifications-dropdown-tab--following" role="tab">Following</span>
            <span class="notifications-dropdown-tab notifications-dropdown-tab--archive" role="tab">Archive</span>
          </div>
          <div class="notifications-dropdown-list">
            <% navbar_items = navbar_notifications %>
            <% if navbar_items.any? %>
              <% navbar_items.each do |notification| %>
                <div class="notifications-dropdown-item" id="notification-dropdown-<%= notification.id %>">
                  <%= link_to notification_row_link(notification), class: 'notifications-dropdown-item-link' do %>
                    <% avatar_src = notification.actor&.avatar_url.presence || 'default-avatar.png' %>
                    <%= image_tag avatar_src, class: 'notifications-dropdown-avatar', alt: '' %>
                    <div class="notifications-dropdown-content">
                      <p class="notifications-dropdown-message"><%= sanitize(notification_message_html(notification), tags: %w[span], attributes: %w[class]) %></p>
                      <span class="notifications-dropdown-time"><%= time_ago_in_words(notification.created_at) %> ago</span>
                    </div>
                  <% end %>
                  <% if peer_request_notification?(notification) && notification.notifiable.respond_to?(:pending?) && notification.notifiable.pending? %>
                    <div class="notifications-dropdown-peer-actions">
                      <%= button_to 'Accept', accept_peers_path(user_id: notification.actor_id, format: :json), method: :post, class: 'notifications-dropdown-accept-btn', params: { notification_dropdown_anchor: notification.id }, form: { class: 'js-notifications-dropdown-peer-form', data: { turbo: false } } %>
                      <%= button_to 'Cancel', remove_peers_path(peer_id: notification.actor_id, format: :json), method: :delete, class: 'notifications-dropdown-cancel-btn', params: { notification_dropdown_anchor: notification.id }, form: { class: 'js-notifications-dropdown-peer-form', data: { turbo: false } } %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <div class="notifications-dropdown-empty">No notifications yet.</div>
            <% end %>
          </div>
          <div class="notifications-dropdown-footer">
            <%= link_to 'View All', notifications_path, class: 'notifications-dropdown-view-all' %>
          </div>
        </div>
      </div>

      <!-- Me (Profile) -->
      <div class="nav-tab me-tab" id="me-tab" data-action="click->dropdown#toggle">
        <% if user_signed_in? %>
          <%= image_tag current_user.avatar_url.presence || 'default-avatar.png', alt: 'Profile', class: 'me-profile-pic' %>
        <% else %>
          <%= image_tag 'default-avatar.png', alt: 'Profile', class: 'me-profile-pic' %>
        <% end %>
        <div class="me-text-arrow">
          <span class="nav-tab-text">Me</span>
          <%= image_tag 'mearrow.svg', alt: 'Arrow', class: 'me-arrow' %>
        </div>
        
        <!-- Dropdown Menu -->
        <div class="dropdown-menu">
          <div class="dropdown-content main-content">
            <div class="settings-menu-container">
              <div class="settings-menu-item <%= 'active' if local_assigns[:active] == 'edit' %>">
                <%= link_to(edit_settings_path, data: { turbo: false }, class: 'settings-menu-link') do %>
                  <div class="settings-icon-wrapper">
                    <%= image_tag('edit-profile.svg', class: 'settings-menu-icon') %>
                  </div>
                  <span class="settings-text">Edit Profile</span>
                <% end %>
              </div>
              
              <div class="settings-menu-item upcoming">
                <div class="settings-menu-link">
                  <div class="settings-icon-wrapper">
                    <%= image_tag('security.png', class: 'settings-menu-icon') %>
                  </div>
                  <span class="settings-text">Security</span>
                </div>
              </div>
              
              <div class="settings-menu-item <%= 'active' if local_assigns[:active] == 'notifications' %>">
                <%= link_to(notifications_settings_path, data: { turbo: false }, class: 'settings-menu-link') do %>
                  <div class="settings-icon-wrapper">
                    <%= image_tag('settings-notification.svg', class: 'settings-menu-icon') %>
                  </div>
                  <span class="settings-text">Notifications</span>
                <% end %>
              </div>
              
              <div class="settings-menu-item <%= 'active' if local_assigns[:active] == 'subscription' %>">
                <%= link_to(subscription_settings_path, data: { turbo: false }, class: 'settings-menu-link') do %>
                  <div class="settings-icon-wrapper">
                    <%= image_tag('Subscription.svg', class: 'settings-menu-icon') %>
                  </div>
                  <span class="settings-text">Subscription</span>
                <% end %>
              </div>
            </div>
            <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item" do %>
              <i class="fas fa-sign-out-alt"></i>
              <span>Log Out</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

 
    <div class="new-claim-btn-wrapper">
      <% if controller_name == 'theories' || request.path.start_with?('/theories') %>
        <%= link_to new_theory_path, class: "new-claim-btn new-theory-btn" do %>
          <%= image_tag 'newclaim.png', alt: 'New Theory', class: 'new-claim-icon' %>
          <span class="new-claim-text">New Theory</span>
        <% end %>
      <% else %>
        <%= link_to new_claim_path, class: "new-claim-btn" do %>
          <%= image_tag 'newclaim.png', alt: 'New Claim', class: 'new-claim-icon' %>
          <span class="new-claim-text">New Claim</span>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>

