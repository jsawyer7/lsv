<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('.challenge-form-ajax');
  const overlay = document.querySelector('.processing-overlay');
  let processingTimeout;

  function showLoader() {
    if (overlay) {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function hideLoader() {
    if (overlay) {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  function startProcessingTimeout() {
    processingTimeout = setTimeout(() => {
      hideLoader();
      if (form) {
        const errorDiv = document.createElement('div');
        errorDiv.className = 'error-messages';
        errorDiv.innerHTML = '<p class="error">The request is taking longer than expected. Please check back in a few moments.</p>';
        form.prepend(errorDiv);
      }
    }, 80000);
  }

  function clearProcessingTimeout() {
    if (processingTimeout) {
      clearTimeout(processingTimeout);
    }
  }

  document.addEventListener('click', function(e) {
    var link = e.target.closest('.challenge-delete-link');
    if (!link) return;
    e.preventDefault();
    var url = link.getAttribute('data-challenge-delete-url');
    var msg = link.getAttribute('data-confirm') || 'Are you sure you want to delete this challenge?';
    if (!url) return;
    if (!confirm(msg)) return;
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    csrfToken = csrfToken ? csrfToken.getAttribute('content') : '';
    fetch(url, {
      method: 'DELETE',
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': csrfToken
      },
      credentials: 'same-origin'
    })
    .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
    .then(function(result) {
      if (result.ok && result.data.status === 'success' && result.data.html !== undefined) {
        var list = document.getElementById('challenges');
        if (list) list.innerHTML = result.data.html;
      } else if (!result.ok && result.data && result.data.errors) {
        alert(result.data.errors.join(', ') || 'Failed to delete challenge.');
      } else {
        window.location.reload();
      }
    })
    .catch(function() {
      alert('An error occurred. Please try again.');
    });
  });

  if (form) form.addEventListener('submit', function(event) {
    event.preventDefault();
  });

  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape' && overlay.classList.contains('active')) {
      hideLoader();
      clearProcessingTimeout();
    }
  });
});
</script>
